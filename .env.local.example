# ─── Supabase ────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (server) ─────────────────────────────────────────
# Developers → API keys + Webhooks → Signing secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Product IDs (Products page in Stripe). Used by the webhook to
# map an incoming purchase to A / B / C.
STRIPE_PRODUCT_CARDS=
STRIPE_PRODUCT_LEAK=
STRIPE_PRODUCT_CIRCLE_ONETIME=
STRIPE_PRODUCT_CIRCLE_MONTHLY=

# ─── Stripe payment links (client-side) ──────────────────────
# Hosted Stripe payment link URLs, used by the paths/signup pages.
NEXT_PUBLIC_STRIPE_CARDS_MONTHLY=
NEXT_PUBLIC_STRIPE_CARDS_YEARLY=
NEXT_PUBLIC_STRIPE_LEAK=
NEXT_PUBLIC_STRIPE_CIRCLE_ONETIME=
NEXT_PUBLIC_STRIPE_CIRCLE_MONTHLY=

# Legacy names referenced in /signup and /upgrade. Set these to
# the same URLs as above (LEAK, CARDS_MONTHLY, CIRCLE_ONETIME).
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
NEXT_PUBLIC_STRIPE_PATH_B_LINK=
NEXT_PUBLIC_STRIPE_PATH_C_LINK=

# ─── App ─────────────────────────────────────────────────────
# Production URL, e.g. https://theenergyleader.com
NEXT_PUBLIC_APP_URL=

# ─── Email (Emailit) ─────────────────────────────────────────
# Settings → API in the Emailit dashboard. Domain must be verified
# (SPF/DKIM) before sends will deliver.
EMAILIT_API_KEY=
EMAILIT_FROM=Nicole <Nicole@theenergyleader.com>
EMAILIT_REPLY_TO=Nicole@theenergyleader.com

# Address that receives admin alerts (Day 7 completions, expiry pings).
ADMIN_NOTIFY_EMAIL=Nicole@theenergyleader.com
